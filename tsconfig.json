{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": ".",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*",
    "BikeRental/src/models/**/*",
    "BikeRental/src/validations/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "BikeRental/src/tests/**/*",
    "BikeRental/src/components/**/*",
    "BikeRental/src/models/rentalLog.ts"
  ]
}
